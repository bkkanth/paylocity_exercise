# ─────────────────────────────────────────────────
# Environment variables for the Vulnerability Tracker API
#
# Copy this file to .env and adjust values as needed:
#   cp .env.example .env        (macOS/Linux)
#   copy .env.example .env      (Windows CMD)
#
# NEVER commit .env to source control.
# It is listed in .gitignore for this reason.
# Real secrets and environment-specific config
# must stay out of the repository.
# ─────────────────────────────────────────────────

# Host the API server binds to.
# 127.0.0.1 = localhost only (dev default — not reachable from other machines)
# 0.0.0.0   = all interfaces (use inside Docker or when exposing to a network)
API_HOST=127.0.0.1

# Port the API server listens on.
# Change this if 8000 is already in use on your machine.
API_PORT=8000
